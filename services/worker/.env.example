# Supabase (Settings → API). Service role bypasses RLS — keep this host secure.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# The Odds API (free tier ~500 credits/month)
ODDS_API_KEY=your-odds-api-key
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# Telegram bot (create via @BotFather). Chat ids live in monitor_segments.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Dashboard base URL for alert links
APP_BASE_URL=https://your-app.vercel.app

# Optional LLM annotation (only used when monitor_configs.llm_enabled = true)
ANTHROPIC_API_KEY=

# Optional error tracking
SENTRY_DSN=
