# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only. Used by API routes for audited config mutations. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shared secret for worker-facing routes (must match services/worker .env)
WORKER_API_TOKEN=generate-a-long-random-string

# Base URL used in Telegram dashboard links
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
